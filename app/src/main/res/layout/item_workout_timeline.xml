<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/fitness_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/fitness_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/sessionFocusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-black"
                android:text="Chest + Triceps"
                android:textColor="@color/fitness_primary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/sessionDateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12/10/2023"
                android:textColor="#A0AAB2"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/sessionExercisesSummaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="Bench Press: 3x10 (60kg)\nChest Fly: 3x12 (15kg)"
            android:textColor="@color/fitness_on_surface"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/sessionStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_primary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="COMPLETED"
            android:textColor="@color/black"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
